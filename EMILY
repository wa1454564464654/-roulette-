let audioCtx = null;
let rouletteInterval = null;

// Safari対応：オーディオの初期化と再利用を確実に行う
function initAudioContext() {
    if (!audioCtx) {
        audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    }
    if (audioCtx.state === 'suspended') {
        audioCtx.resume();
    }
}

// Safari対応：ノードを毎回確実に切断し、メモリの上限エラーを防ぐ
function playTickSound() {
    try {
        initAudioContext();
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = 'sine';
        osc.frequency.setValueAtTime(880, audioCtx.currentTime);
        gain.gain.setValueAtTime(0.08, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.05);
        
        // メモリリーク防止用の確実な切断
        setTimeout(() => {
            osc.disconnect();
            gain.disconnect();
        }, 100);
    } catch(e) { console.log(e); }
}

function playRouletteSound() {
    stopRouletteSound();
    rouletteInterval = setInterval(playTickSound, 120);
}

function stopRouletteSound() {
    if (rouletteInterval) {
        clearInterval(rouletteInterval);
        rouletteInterval = null;
    }
}

function playResultSound() {
    try {
        initAudioContext();
        const now = audioCtx.currentTime;
        const notes = [523.25, 659.25, 783.99, 1046.50];
        notes.forEach((freq, index) => {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(freq, now + index * 0.1);
            gain.gain.setValueAtTime(0.1, now + index * 0.1);
            gain.gain.exponentialRampToValueAtTime(0.001, now + index * 0.1 + 0.4);
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.start(now + index * 0.1);
            osc.stop(now + index * 0.1 + 0.4);
            
            setTimeout(() => {
                osc.disconnect();
                gain.disconnect();
            }, 600);
        });
    } catch(e) { console.log(e); }
}

function renderList() {
    const kw = document.getElementById('searchInput').value.toLowerCase();
    const list = allSongs.filter(s => s.toLowerCase().includes(kw));
    
    document.getElementById('songCount').innerText = allSongs.length;
    document.getElementById('searchCount').innerText = list.length;
    
    document.getElementById('songList').innerHTML = list.map(s => `
        <div class="list-item">
            <span>${s}</span>
            <span class="del-btn" onclick="removeSong('${s.replace(/\\/g,'\\\\').replace(/'/g,"\\'")}')">×</span>
        </div>
    `).join('');
}

function removeSong(name) {
    allSongs = allSongs.filter(s => s !== name);
    renderList();
}

function addSong() {
    const inp = document.getElementById('addInput');
    const val = inp.value.trim();
    if (val && !allSongs.includes(val)) {
        allSongs.unshift(val); 
        inp.value = '';
        renderList();
    }
}

function firePawHearts() {
    ['ph1','ph2','ph3'].forEach((id, i) => {
        const h = document.getElementById(id);
        if(!h) return;
        h.classList.remove('go');
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                setTimeout(() => h.classList.add('go'), i * 75);
            });
        });
    });
}

function triggerPawPress() {
    const btn = document.getElementById('pawBtn');
    if(!btn) return;
    btn.classList.remove('pressed');
    requestAnimationFrame(() => {
        requestAnimationFrame(() => {
            btn.classList.add('pressed');
            firePawHearts();
            setTimeout(() => btn.classList.remove('pressed'), 320);
        });
    });
}

function hideAll() {
    ['slot-default','anim-slot','anim-countdown','anim-card','anim-roulette','anim-garagara','result-display']
        .forEach(id => {
            const el = document.getElementById(id);
            if(el) el.style.display = 'none';
        });
}

function showResult(songs) {
    stopRouletteSound();
    playResultSound();

    songs.forEach(song => {
        allSongs = allSongs.filter(s => s !== song);
    });
    for(let i = songs.length - 1; i >= 0; i--) {
        allSongs.unshift(songs[i]);
    }

    renderList();
    hideAll();
    
    const el = document.getElementById('result-display');
    if(!el) return;
    el.style.display = 'flex';
    
    el.innerHTML = songs.map((s, i) => {
        const escapedSong = s.replace(/\\/g, '\\\\').replace(/'/g, "\\'");
        return `
            <div class="result-row" id="resRow_${i}" style="animation-delay:${i*0.12}s">
                <span class="result-song-text">✨ ${s}</span>
                <div class="result-del-btn" title="この曲をリストから削除" onclick="removeSongFromResult('${escapedSong}', ${i})">×</div>
            </div>
        `;
    }).join('');

    setTimeout(() => {
        const container = document.getElementById('zoomContainer');
        if (container) {
            container.classList.remove('zoomed');
        }
        const btn = document.getElementById('pawBtn');
        if(btn) btn.disabled = false;
    }, 5000); 
}

function removeSongFromResult(songName, index) {
    allSongs = allSongs.filter(s => s !== songName);
    renderList();
    
    const row = document.getElementById(`resRow_${index}`);
    if(row) {
        row.classList.add('deleted');
        const txt = row.querySelector('.result-song-text');
        if(txt) txt.textContent = `🗑️ 削除しました`;
        const delBtn = row.querySelector('.result-del-btn');
        if(delBtn) delBtn.style.display = 'none';
    }
}

function setBadge(name) {
    const b = document.getElementById('effect-badge');
    if(!b) return;
    b.textContent = name;
    b.classList.add('show');
    setTimeout(() => b.classList.remove('show'), 2200);
}

/* 演出A: スロット */
function effectSlot(pool, finalSongs) {
    return new Promise((resolve) => {
        setBadge('🎰 スロット');
        hideAll();
        const wrap = document.getElementById('anim-slot');
        if(!wrap) { resolve(); return; }
        wrap.style.display = 'flex';

        const REELS = 3;
        wrap.innerHTML = '';
        const reelEls = [];
        for (let r = 0; r < REELS; r++) {
            const reel = document.createElement('div');
            reel.className = 'slot-reel';
            const inner = document.createElement('div');
            inner.className = 'slot-reel-inner';
            reel.appendChild(inner);
            wrap.appendChild(reel);
            reelEls.push(inner);
        }

        const ITEM_H = 72;
        const positions = [0, 0, 0];
        const speeds = [18, 14, 10];

        function buildItems(inner, songs, extra) {
            inner.innerHTML = '';
            const list = [];
            for (let i = 0; i < extra; i++) list.push(songs[Math.floor(Math.random()*songs.length)]);
            list.forEach(s => {
                const d = document.createElement('div');
                d.className = 'reel-item';
                d.textContent = s;
                inner.appendChild(d);
            });
        }

        const mainPool = pool.length > 0 ? pool : finalSongs;
        for (let r = 0; r < REELS; r++) buildItems(reelEls[r], mainPool, 40);

        let frame = 0;
        const stopFrames = [40, 65, 90];
        let stopped = [false, false, false];
        
        const repSong = finalSongs[0]; 
        const finalItems = [
            mainPool[Math.floor(Math.random()*mainPool.length)] || repSong,
            mainPool[Math.floor(Math.random()*mainPool.length)] || repSong,
            repSong
        ];

        function animate() {
            frame++;
            for (let r = 0; r < REELS; r++) {
                if (stopped[r]) continue;
                positions[r] += speeds[r];
                const totalH = reelEls[r].childElementCount * ITEM_H;
                if (positions[r] >= totalH - ITEM_H * 5) positions[r] = 0;
                
                // Safari用translate3d最適化
                reelEls[r].style.transform = `translate3d(0, -${positions[r]}px, 0)`;

                if (frame >= stopFrames[r]) {
                    stopped[r] = true;
                    const lastItem = document.createElement('div');
                    lastItem.className = 'reel-item';
                    lastItem.textContent = finalItems[r];
                    lastItem.style.color = '#ff1493';
                    lastItem.style.fontSize = '12px';
                    reelEls[r].innerHTML = '';
                    reelEls[r].appendChild(lastItem);
                    reelEls[r].style.transform = 'translate3d(0, 0, 0)';
                }
            }
            if (!stopped.every(Boolean)) {
                requestAnimationFrame(animate);
            } else {
                setTimeout(() => {
                    showResult(finalSongs);
                    resolve();
                }, 600);
            }
        }
        requestAnimationFrame(animate);
    });
}

/* 演出B: カウントダウン */
async function effectCountdown(pool, finalSongs) {
    setBadge('💥 カウントダウン');
    hideAll();
    const cd = document.getElementById('anim-countdown');
    const num = document.getElementById('countdown-num');
    const res = document.getElementById('countdown-result');
    if(!cd || !num || !res) return;
    cd.style.display = 'flex';
    res.textContent = '';

    for (let n = 3; n >= 1; n--) {
        num.textContent = n;
        num.style.color = n === 1 ? '#ff1493' : n === 2 ? '#ff4da6' : '#ff69b4';
        const w = document.getElementById('slot-wrap');
        if(w) w.classList.remove('cd-flashing');
        
        await new Promise(r => requestAnimationFrame(() => requestAnimationFrame(r)));
        if(w) w.classList.add('cd-flashing');
        await new Promise(r => setTimeout(r, 700));
    }
    num.textContent = '🎵';
    num.style.color = '#ff1493';
    res.textContent = finalSongs.length === 1 ? finalSongs[0] : `計 ${finalSongs.length} 曲 当選！`;
    const w = document.getElementById('slot-wrap');
    if(w) w.classList.add('cd-flashing');
    await new Promise(r => setTimeout(r, 900));
    showResult(finalSongs);
}

/* 演出C: カードめくり */
function effectCard(pool, finalSongs) {
    return new Promise((resolve) => {
        setBadge('🃏 選んでカードめくり');
        hideAll();
        const wrap = document.getElementById('anim-card');
        if(!wrap) { resolve(); return; }
        wrap.style.display = 'flex';
        wrap.innerHTML = '';

        let cardsData = [];
        const CARDS_COUNT = Math.max(4, finalSongs.length + 2); 

        let targetSongs = [...finalSongs];
        let dummyPool = pool.length > 0 ? pool : allSongs.filter(s => !finalSongs.includes(s));
        if (dummyPool.length === 0) dummyPool = ["Lucky Song♪"];

        for (let i = 0; i < CARDS_COUNT; i++) {
            if (targetSongs.length > 0) {
                cardsData.push({ song: targetSongs.pop(), isWin: true });
            } else {
                const randDummy = dummyPool[Math.floor(Math.random() * dummyPool.length)];
                cardsData.push({ song: randDummy, isWin: false });
            }
        }
        cardsData.sort(() => Math.random() - 0.5);

        let winCountNeeded = finalSongs.length; 
        let openedWinCount = 0;
        let isLock = false; 

        cardsData.forEach((data) => {
            const card = document.createElement('div');
            card.className = 'play-card selectable';
            card.innerHTML = `
                <div class="play-card-inner">
                    <div class="card-back">🐾</div>
                    <div class="card-face"></div>
                </div>`;
            card.querySelector('.card-face').textContent = data.song;
            wrap.appendChild(card);

            card.addEventListener('click', async () => {
                if (isLock || card.classList.contains('flipped')) return;
                isLock = true;

                playTickSound();

                card.classList.remove('selectable');
                card.classList.add('flipped');

                if (data.isWin) {
                    openedWinCount++;
                    card.querySelector('.card-face').style.color = '#ff1493';
                    card.querySelector('.card-face').style.fontSize = '10px';
                    card.querySelector('.card-face').style.background = '#fff0f5';
                } else {
                    card.querySelector('.card-face').style.color = '#aaa';
                }

                if (openedWinCount === winCountNeeded) {
                    stopRouletteSound();
                    await new Promise(r => setTimeout(r, 1000));
                    
                    const allCards = wrap.querySelectorAll('.play-card');
                    allCards.forEach(c => {
                        if (!c.classList.contains('flipped')) {
                            c.classList.remove('selectable');
                            c.classList.add('flipped');
                        }
                    });

                    await new Promise(r => setTimeout(r, 1500));
                    showResult(finalSongs); 
                    resolve();
                } else {
                    setTimeout(() => { isLock = false; }, 300);
                }
            });
        });
    });
}

/* 演出D: ルーレット */
function effectRoulette(pool, finalSongs) {
    return new Promise((resolve) => {
        setBadge('🌀 ルーレット');
        hideAll();
        const wrap = document.getElementById('anim-roulette');
        if(!wrap) { resolve(); return; }
        wrap.style.display = 'flex';

        const inner = document.getElementById('roulette-inner');
        if(!inner) { resolve(); return; }
        inner.innerHTML = '';

        const repSong = finalSongs[0];
        const items = [];
        const loopPool = pool.length > 0 ? pool : [repSong];
        for (let i = 0; i < 30; i++) items.push(loopPool[Math.floor(Math.random()*loopPool.length)]);
        items.push(repSong);

        const ITEM_H = 54;
        items.forEach(s => {
            const d = document.createElement('div');
            d.className = 'roulette-item';
            d.textContent = s;
            inner.appendChild(d);
        });

        const totalDist = items.length * ITEM_H - ITEM_H;
        const duration = 2800;
        const start = performance.now();

        function easeOut(t) { return 1 - Math.pow(1 - t, 4); }

        function step(now) {
            const elapsed = now - start;
            const t = Math.min(elapsed / duration, 1);
            const pos = easeOut(t) * totalDist;
            
            // Safari用translate3d最適化
            inner.style.transform = `translate3d(0, -${pos}px, 0)`;
            if (t < 1) {
                requestAnimationFrame(step);
            } else {
                inner.style.transform = `translate3d(0, -${totalDist}px, 0)`;
                setTimeout(() => {
                    showResult(finalSongs);
                    resolve();
                }, 600);
            }
        }
        requestAnimationFrame(step);
    });
}

/* 演出E: ガラガラ */
function effectGaragara(pool, finalSongs) {
    return new Promise((resolve) => {
        setBadge('🎊 ガラガラポン');
        hideAll();
        
        const wrap = document.getElementById('anim-garagara');
        const wheel = document.getElementById('gWheel');
        const ball = document.getElementById('gBall');
        const text = document.getElementById('garagara-text');
        
        if(!wrap || !wheel || !ball || !text) { resolve(); return; }
        
        wrap.style.display = 'flex';
        wheel.classList.remove('spinning');
        ball.classList.remove('dropped');
        ball.style.opacity = '0';
        text.textContent = '回るよ〜！';
        
        const colors = ['#ff2a6d', '#ffd700', '#05d9e8', '#ff69b4', '#39ff14', '#ffffff'];
        ball.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
        
        requestAnimationFrame(() => {
            requestAnimationFrame(() => {
                wheel.classList.add('spinning');
                ball.classList.add('dropped');
            });
        });

        let tickCount = 0;
        const tickTimer = setInterval(() => {
            playTickSound();
            tickCount++;
            if(tickCount >= 12) clearInterval(tickTimer);
        }, 150);

        setTimeout(() => {
            text.textContent = finalSongs.length === 1 ? '何が出るかな？' : `計 ${finalSongs.length} 曲 当選！`;
        }, 1800);

        setTimeout(() => {
            clearInterval(tickTimer);
            showResult(finalSongs);
            resolve();
        }, 2600);
    });
}

const EFFECTS = [
    { name: 'slot',      fn: effectSlot },
    { name: 'countdown', fn: effectCountdown },
    { name: 'card',      fn: effectCard },
    { name: 'roulette',  fn: effectRoulette },
    { name: 'garagara',  fn: effectGaragara }
];

async function startSlot() {
    const kw = document.getElementById('searchInput').value.toLowerCase();
    let pool = allSongs.filter(s => s.toLowerCase().includes(kw));
    if (pool.length < 1) { alert('曲が足りません！'); return; }

    const selectEl = document.getElementById('selectCount');
    let count = parseInt(selectEl.value, 10) || 1;
    if (count > pool.length) count = pool.length;

    const btn = document.getElementById('pawBtn');
    if(btn) btn.disabled = true;
    triggerPawPress();

    // Safari必須：ユーザーのタップ直後のスレッドでオーディオコンテキストをアクティブにする
    initAudioContext();

    const container = document.getElementById('zoomContainer');
    if (container) {
        container.classList.add('zoomed');
    }

    playRouletteSound(); 

    const effect = EFFECTS[Math.floor(Math.random() * EFFECTS.length)];

    const finalSongs = [];
    const p = [...pool];
    for (let i = 0; i < count; i++) {
        const idx = Math.floor(Math.random() * p.length);
        finalSongs.push(p.splice(idx, 1)[0]);
    }

    try {
        await effect.fn(p, finalSongs);
    } catch(e) {
        console.log("Effect animation error", e);
        showResult(finalSongs); 
    }
}

