<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>EMILY's ルーレット選曲</title>
    <style>
        * { 
            box-sizing: border-box; 
            margin: 0; 
            padding: 0; 
            touch-action: manipulation;
            -webkit-tap-highlight-color: transparent; /* タップ時の青い影を消す */
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background: #fff0f5;
            padding: 20px 15px;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            overflow-x: hidden;
        }

        /* 全体コンテナ */
        .zoom-container {
            width: 100%;
            max-width: 600px; /* iPadの横幅（縦持ち・横持ち両対応）に最適なサイズ */
            transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
            transform-origin: center top;
            -webkit-transform-style: preserve-3d;
            transform-style: preserve-3d;
        }
        .zoom-container.zoomed {
            transform: scale(1.15); /* Safariでボケない程度にマイルドに拡大 */
        }

        .main-wrapper {
            display: flex;
            flex-direction: column;
            gap: 20px;
            width: 100%;
        }

        /* 【上側】抽選エリア */
        .top-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 20px;
            width: 100%;
            background: rgba(255,255,255,0.95);
            padding: 24px 20px;
            border-radius: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }

        /* 【中央】肉球ボタンエリア */
        .button-section {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%;
            min-height: 130px;
        }

        /* 【下側】楽曲管理エリア */
        .bottom-section {
            width: 100%;
            background: rgba(255,255,255,0.9);
            padding: 20px;
            border-radius: 20px;
            border: 2px solid #ffb6c1;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02);
        }

        h1 { font-size: 24px; color: #d63384; text-align: center; font-weight: bold; }

        #slot-wrap {
            width: 100%;
            max-width: 380px;
            min-height: 120px;
            border: 8px solid #ffb6c1;
            border-radius: 40px;
            box-shadow: 0 10px 0 #ff69b4;
            background: #fff;
            overflow: hidden;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            -webkit-transform: translate3d(0,0,0); /* Safariのちらつきバグ防止 */
            transform: translate3d(0,0,0);
        }

        #slot-default {
            font-size: 22px;
            font-weight: bold;
            padding: 28px 20px;
            text-align: center;
            color: #d63384;
        }

        /* ── 演出A: スロット ── */
        #anim-slot {
            display: none;
            width: 100%;
            padding: 12px 6px;
            gap: 4px;
            justify-content: center;
        }
        .slot-reel {
            flex: 1;
            height: 72px;
            overflow: hidden;
            border: 2px solid #ffb6c1;
            border-radius: 10px;
            position: relative;
            background: #fff8fb;
        }
        .slot-reel-inner {
            position: absolute;
            width: 100%;
            top: 0;
            transition: none;
            -webkit-transform: translate3d(0,0,0);
            transform: translate3d(0,0,0);
        }
        .slot-reel-inner .reel-item {
            height: 72px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
            color: #c2185b;
            text-align: center;
            padding: 4px;
            line-height: 1.3;
            border-bottom: 1px solid #ffe4ec;
        }
        .slot-reel::before, .slot-reel::after {
            content: ''; position: absolute; left: 0; right: 0; height: 22px; z-index: 2; pointer-events: none;
        }
        .slot-reel::before { top: 0;    background: linear-gradient(to bottom, rgba(255,255,255,0.85), transparent); }
        .slot-reel::after  { bottom: 0; background: linear-gradient(to top,   rgba(255,255,255,0.85), transparent); }

        /* ── 演出B: カウントダウン ── */
        #anim-countdown {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 16px;
            gap: 6px;
        }
        #countdown-num {
            font-size: 64px;
            font-weight: 900;
            color: #ff1493;
            line-height: 1;
        }
        #countdown-result {
            font-size: 14px;
            font-weight: bold;
            color: #c2185b;
            text-align: center;
            min-height: 26px;
        }

        @keyframes cd-flash {
            0%   { background: #ff69b4; }
            100% { background: #fff; }
        }
        .cd-flashing { animation: cd-flash 0.18s ease-out; }

        /* ── 演出C: カードめくり ── */
        #anim-card {
            display: none;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 12px;
            gap: 8px;
            flex-wrap: wrap;
        }
        .play-card {
            width: 68px;
            height: 84px;
            -webkit-perspective: 600px;
            perspective: 600px;
            cursor: pointer;
        }
        .play-card-inner {
            position: relative;
            width: 100%;
            height: 100%;
            -webkit-transform-style: preserve-3d;
            transform-style: preserve-3d;
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .play-card.flipped .play-card-inner { 
            -webkit-transform: rotateY(180deg);
            transform: rotateY(180deg); 
        }
        .card-face, .card-back {
            position: absolute;
            inset: 0;
            border-radius: 8px;
            -webkit-backface-visibility: hidden;
            backface-visibility: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #ffb6c1;
        }
        .card-back {
            background: linear-gradient(135deg, #ff69b4 0%, #ffb6c1 50%, #ff69b4 100%);
            font-size: 24px;
            color: #fff;
        }
        .card-face {
            background: #fff;
            -webkit-transform: rotateY(180deg);
            transform: rotateY(180deg);
            font-size: 10px;
            font-weight: bold;
            color: #c2185b;
            text-align: center;
            padding: 4px;
            line-height: 1.3;
        }

        /* ── 演出D: ルーレット ── */
        #anim-roulette {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 20px 16px;
            gap: 4px;
        }
        #roulette-band {
            width: 100%;
            max-width: 300px;
            height: 54px;
            overflow: hidden;
            border: 3px solid #ff69b4;
            border-radius: 12px;
            position: relative;
            background: #fff8fb;
        }
        #roulette-band::before, #roulette-band::after {
            content: ''; position: absolute; left: 0; right: 0; height: 16px; z-index: 2; pointer-events: none;
        }
        #roulette-band::before { top: 0;    background: linear-gradient(to bottom, rgba(255,255,255,0.9), transparent); }
        #roulette-band::after  { bottom: 0; background: linear-gradient(to top,   rgba(255,255,255,0.9), transparent); }
        #roulette-inner {
            position: absolute;
            width: 100%;
            -webkit-transform: translate3d(0,0,0);
            transform: translate3d(0,0,0);
        }
        .roulette-item {
            height: 54px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: bold;
            color: #c2185b;
            text-align: center;
            padding: 4px 8px;
        }
        #roulette-arrows {
            display: flex; gap: 6px; font-size: 13px; color: #ff69b4;
        }

        /* ── 演出E: ガラガラ ── */
        #anim-garagara {
            display: none;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 10px;
            gap: 8px;
        }
        .g-container {
            position: relative;
            width: 70px;
            height: 70px;
        }
        .g-wheel {
            width: 100%;
            height: 100%;
            border: 6px double #d4af37;
            background: linear-gradient(135deg, #fff3cd 0%, #ffeeba 100%);
            border-radius: 16px;
            position: absolute;
            top: 0; left: 0;
            transform-origin: center center;
            -webkit-transform: translate3d(0,0,0);
            transform: translate3d(0,0,0);
        }
        @keyframes g-spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(1080deg); }
        }
        .g-wheel.spinning {
            animation: g-spin 2.2s cubic-bezier(0.4, 0.1, 0.2, 1) forwards;
        }
        .g-stand {
            position: absolute;
            bottom: -6px; left: 15px;
            width: 40px; height: 10px;
            border-top: 3px solid #856404;
            border-left: 6px solid transparent;
            border-right: 6px solid transparent;
        }
        .g-ball {
            position: absolute;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            bottom: -2px; left: 27px;
            opacity: 0;
            transform: scale(0);
            box-shadow: inset -2px -2px 4px rgba(0,0,0,0.2), 0 2px 4px rgba(0,0,0,0.15);
        }
        @keyframes ball-drop {
            0% { transform: translate3d(0, -10px, 0) scale(0.3); opacity: 0; }
            40% { transform: translate3d(0, 14px, 0) scale(1.2); opacity: 1; }
            70% { transform: translate3d(0, 10px, 0) scale(1.0); opacity: 1; }
            100% { transform: translate3d(0, 12px, 0) scale(1.0); opacity: 1; }
        }
        .g-ball.dropped {
            animation: ball-drop 0.5s ease-out 1.8s both;
        }
        .g-dish {
            width: 32px; height: 8px;
            background: #e2e3e5;
            border-radius: 0 0 10px 10px;
            border: 1px solid #ced4da;
            margin-top: 10px;
        }
        #garagara-text {
            font-size: 11px;
            font-weight: bold;
            color: #856404;
            min-height: 14px;
            text-align: center;
        }

        .count-badge {
            font-size: 12px;
            background: #ffe4ec;
            color: #d63384;
            border: 1px solid #ffb6c1;
            padding: 4px 10px;
            border-radius: 8px;
            font-weight: bold;
        }

        /* 結果表示 */
        #result-display {
            display: none;
            width: 100%;
            padding: 16px 12px;
            text-align: center;
            font-size: 16px;
            font-weight: bold;
            color: #ff1493;
            flex-direction: column;
            gap: 10px;
            max-height: 250px;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }
        @keyframes result-pop {
            0%   { transform: scale(0.6); opacity: 0; }
            60%  { transform: scale(1.05); opacity: 1; }
            100% { transform: scale(1); }
        }
        .result-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 240, 245, 0.85);
            padding: 8px 14px;
            border-radius: 20px;
            border: 1px dashed #ffb6c1;
            gap: 8px;
            width: 100%;
            max-width: 340px;
            margin: 0 auto;
            animation: result-pop 0.45s cubic-bezier(0.34,1.56,0.64,1) both;
        }
        .result-song-text {
            text-shadow: 0 0 12px rgba(255,105,180,0.4);
            flex: 1;
            text-align: left;
            font-size: 13px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            line-height: 1.2;
        }
        .result-del-btn {
            background: #fff;
            color: #ff69b4;
            border: 1px solid #ff69b4;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            cursor: pointer;
            font-weight: bold;
            transition: all 0.15s;
            flex-shrink: 0;
        }

        /* 立体肉球ボタン（Safari用に調整） */
        .paw-btn {
            position: relative;
            width: 130px;
            height: 125px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 0;
            outline: none;
            transform-origin: center bottom;
        }
        .paw-btn:disabled { opacity: 0.6; cursor: not-allowed; }

        .main-pad {
            position: absolute; left: 50%; bottom: 0; transform: translateX(-50%);
            width: 84px; height: 76px;
            background: radial-gradient(ellipse at 38% 32%, #ffdde6 0%, #ffb3c6 38%, #ff85a1 72%, #e8607e 100%);
            border-radius: 50% 50% 46% 46% / 56% 56% 44% 44%;
            box-shadow: 0 6px 0 #d4506a, 0 8px 16px rgba(200,60,90,0.3), inset 0 -4px 8px rgba(180,40,70,0.18), inset 0 6px 14px rgba(255,230,235,0.6);
        }
        .toe {
            position: absolute;
            background: radial-gradient(ellipse at 35% 28%, #ffdde6 0%, #ffb3c6 40%, #ff85a1 75%, #e8607e 100%);
            border-radius: 50%;
            box-shadow: 0 3px 0 #d4506a, 0 5px 10px rgba(200,60,90,0.25), inset 0 -2px 5px rgba(180,40,70,0.15), inset 0 4px 8px rgba(255,235,240,0.55);
        }
        .toe-1 { width: 32px; height: 30px; top: 10px; left: 8px; }
        .toe-2 { width: 37px; height: 35px; top: 1px;  left: 34px; }
        .toe-3 { width: 37px; height: 35px; top: 1px;  right: 34px; }
        .toe-4 { width: 32px; height: 30px; top: 10px; right: 8px; }

        @keyframes paw-squish {
            0%   { transform: translateX(-50%) scaleY(1)    scaleX(1); }
            40%  { transform: translateX(-50%) scaleY(0.88) scaleX(1.07); }
            100% { transform: translateX(-50%) scaleY(1)    scaleX(1); }
        }
        @keyframes toe-squish {
            0%   { transform: scale(1)    translateY(0); }
            40%  { transform: scale(0.85) translateY(2px); }
            100% { transform: scale(1)    translateY(0); }
        }
        .paw-btn.pressed .main-pad { animation: paw-squish 0.22s ease-out forwards; }
        .paw-btn.pressed .toe      { animation: toe-squish  0.22s ease-out forwards; }

        .paw-hearts {
            position: absolute; top: -8px; left: 50%; transform: translateX(-50%); pointer-events: none; width: 0; height: 0;
        }
        .paw-heart { position: absolute; font-size: 17px; opacity: 0; }
        @keyframes heart-float {
            0%   { opacity: 1;   transform: translate3d(var(--hx), 0, 0) scale(0.5); }
            100% { opacity: 0;   transform: translate3d(var(--hx), -60px, 0) scale(1.2); }
        }
        .paw-heart.go { animation: heart-float 0.7s ease-out forwards; }

        #effect-badge {
            font-size: 12px; background: #ff69b4; color: #fff; border-radius: 20px; padding: 4px 12px; opacity: 0; transition: opacity 0.3s;
            margin-top: 5px; font-weight: bold;
        }
        #effect-badge.show { opacity: 1; }

        .controls {
            background: #fff; padding: 12px; border-radius: 15px; border: 2px solid #ffb6c1; display: flex; align-items: center; gap: 10px; flex-wrap: wrap; width: 100%;
            justify-content: center;
        }
        .controls input[type="text"] {
            border: 1px solid #ffb6c1; border-radius: 8px; padding: 10px; font-size: 16px; outline: none; flex: 1; min-width: 140px;
            -webkit-appearance: none;
        }
        
        .controls select {
            border: 1px solid #ffb6c1; border-radius: 8px; padding: 10px 28px 10px 12px; font-size: 16px; color: #c2185b; background-color: #fff; outline: none; cursor: pointer; font-weight: bold;
            -webkit-appearance: none; appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'><path fill='%23ff69b4' d='M0 0l5 6 5-6z'/></svg>");
            background-repeat: no-repeat; background-position: right 10px center;
        }
        .controls label { font-size: 14px; color: #d63384; font-weight: bold; }

        .bottom-section h3 { color: #d63384; margin-bottom: 12px; font-size: 17px; font-weight: bold; }
        
        /* iPad用スクロールエリア最適化 */
        #songList {
            max-height: 280px;
            overflow-y: auto;
            -webkit-overflow-scrolling: touch; /* 滑らかなスクロール */
        }
        .list-item {
            padding: 12px 8px; border-bottom: 1px solid #ffe4ec; display: flex; justify-content: space-between; align-items: center; font-size: 15px;
        }
        .del-btn {
            cursor: pointer; color: #ff69b4; font-weight: bold; background: #fff; padding: 8px 14px; border-radius: 8px; border: 1px solid #ffb6c1; flex-shrink: 0; font-size: 14px;
        }
        .add-area { display: flex; gap: 8px; margin-bottom: 16px; }
        .add-area input {
            flex: 1; border: 1px solid #ffb6c1; border-radius: 8px; padding: 10px 12px; font-size: 16px; outline: none; -webkit-appearance: none;
        }
        .add-area button {
            background: #ff69b4; color: #fff; border: none; border-radius: 8px; padding: 10px 18px; cursor: pointer; font-size: 15px; font-weight: bold;
        }
    </style>
</head>
<body>

<div class="zoom-container" id="zoomContainer">
    <div class="main-wrapper">
        
        <div class="top-section">
            <h1>🐾 EMILY's ルーレット選曲 🐾</h1>

            <div class="controls">
                <label>🔍 検索</label>
                <input type="text" id="searchInput" placeholder="アーティスト・曲名…" oninput="renderList()">
                
                <div class="count-badge">該当: <span id="searchCount">0</span>曲</div>

                <label>選曲数</label>
                <select id="selectCount">
                    <option value="1" selected>1曲</option>
                    <option value="2">2曲</option>
                    <option value="3">3曲</option>
                    <option value="4">4曲</option>
                    <option value="5">5曲</option>
                    <option value="6">6曲</option>
                    <option value="7">7曲</option>
                    <option value="8">8曲</option>
                    <option value="9">9曲</option>
                    <option value="10">10曲</option>
                </select>
            </div>

            <div id="slot-wrap">
                <div id="slot-default">準備OK？</div>
                <div id="anim-slot"></div>
                <div id="anim-countdown">
                    <div id="countdown-num">3</div>
                    <div id="countdown-result"></div>
                </div>
                <div id="anim-card"></div>
                <div id="anim-roulette">
                    <div id="roulette-arrows">▼ LUCKY DRAW ▼</div>
                    <div id="roulette-band"><div id="roulette-inner"></div></div>
                </div>
                <div id="anim-garagara">
                    <div class="g-container">
                        <div class="g-wheel" id="gWheel"></div>
                        <div class="g-stand"></div>
                        <div class="g-ball" id="gBall"></div>
                    </div>
                    <div class="g-dish"></div>
                    <div id="garagara-text"></div>
                </div>
                <div id="result-display"></div>
            </div>

            <div id="effect-badge"></div>
        </div>

        <div class="button-section">
            <button class="paw-btn" id="pawBtn" onclick="startSlot()" aria-label="ルーレット開始">
                <div class="paw-hearts" id="pawHearts">
                    <span class="paw-heart" style="--hx:-24px" id="ph1">🌸</span>
                    <span class="paw-heart" style="--hx:2px"   id="ph2">✨</span>
                    <span class="paw-heart" style="--hx:22px"  id="ph3">💕</span>
                </div>
                <div class="toe toe-1"></div>
                <div class="toe toe-2"></div>
                <div class="toe toe-3"></div>
                <div class="toe toe-4"></div>
                <div class="main-pad"></div>
            </button>
        </div>

        <div class="bottom-section">
            <h3>楽曲管理（全 <span id="songCount">0</span> 曲）</h3>
            <div class="add-area">
                <input type="text" id="addInput" placeholder="曲を追加… 例: ZARD - 負けないで" onkeydown="if(event.key==='Enter')addSong()">
                <button onclick="addSong()">＋ 追加</button>
            </div>
            <div id="songList"></div>
        </div>
        
    </div>
</div>

